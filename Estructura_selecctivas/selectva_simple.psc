Algoritmo selectiva_simple
	//averiguar el mayor de dos numeros
	definir n1, n2 Como entero;
	escribir "ingrese el primer numero";
	leer n1;
	escribir "ingrese el segundo numero";
	leer n2;
	si n1>=n2 Entonces
		escribir "el mayor es :",n1;
		
	FinSi
	si n2>=n1 entonces 
		Escribir "el mayor es :",n2;
	FinSi
FinAlgoritmo
